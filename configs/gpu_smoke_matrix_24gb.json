  "seeds": [0],
  "max_new_tokens": 128,
  "temperature": 0.0,
  "mitigation": {
    "triggered_escalation": {
      "enabled": true,
      "block_on_high_severity": true,
      "ask_confirmation_on_irreversible": true,
      "rerun_with_safer_profile": false
