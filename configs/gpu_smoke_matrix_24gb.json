    {
      "name": "pruned_magnitude_20",
      "quantization": "pruned",
      "metadata": {
        "pruning_amount": 0.2,
        "max_pruned_modules": 16
      }
    }
  ],
  "task_paths": [
    "data/tasks/utility_core.json",
    "data/tasks/agentdojo_minimal.json",
    "data/tasks/custom_safety.json",
    "data/tasks/chat_safety_probes.json",
