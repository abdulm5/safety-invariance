{
  "output_root": "runs/gpu_smoke_24gb",
  "report_path": "reports/gpu_smoke_24gb.md",
  "models": [
    {
      "provider": "hf",
      "model_id": "Qwen/Qwen2.5-3B-Instruct",
      "device_map": "auto",
      "torch_dtype": "float16",
      "metadata": {
        "label": "qwen25_3b_gpu_smoke",
        "role": "gpu_smoke"
      }
    }
  ],
  "transforms": [
    {
      "name": "fp16",
      "quantization": "none"
    },
    {
