{
  "judges": [
    {
      "name": "wildguard",
      "provider": "hf",
      "model_id": "allenai/wildguard",
      "device_map": "auto",
      "torch_dtype": "float16",
      "role": "primary_open_safety_judge",
      "labels": [
        "prompt_harmfulness",
        "response_harmfulness",
        "refusal_or_compliance"
      ],
      "metadata": {
        "rationale": "Open moderation model for malicious prompt detection, response risk detection, and refusal evaluation."
      }
    },
    {
      "name": "llama_guard_3_8b",
      "provider": "hf",
      "model_id": "meta-llama/Llama-Guard-3-8B",
      "device_map": "auto",
      "torch_dtype": "float16",
      "role": "secondary_open_safety_judge",
      "labels": [
        "safe",
        "unsafe",
        "hazard_category"
      ],
      "metadata": {
        "rationale": "Independent guard model to check that results are not an artifact of one judge.",
        "access_note": "Requires accepting Meta Llama Guard terms and using an authenticated Hugging Face token."
      }
    }
  ],
  "human_audit": {
    "enabled": true,
    "sample_fraction": 0.1,
    "minimum_examples_per_failure_type": 10,
    "stratify_by": [
      "model",
      "transform",
      "safety_event_kind"
    ]
  }
}
