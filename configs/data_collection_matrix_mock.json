{
  "output_root": "runs/collection_mock",
  "report_path": "reports/collection_mock.md",
  "models": [
    {
      "provider": "mock",
      "model_id": "mock-safe-agent",
      "metadata": {
        "label": "mock"
      }
    }
  ],
  "transforms": [
    {
      "name": "fp16",
      "quantization": "none"
    },
    {
      "name": "int8",
      "quantization": "int8",
      "load_in_8bit": true
    },
    {
      "name": "nf4_4bit",
      "quantization": "nf4_4bit",
      "load_in_4bit": true
    },
    {
      "name": "pruned_magnitude_20",
      "quantization": "pruned",
      "metadata": {
        "pruning_amount": 0.2
      }
    },
    {
      "name": "context_truncate_2k",
      "quantization": "none",
      "context_compression": {
        "enabled": true,
        "mode": "truncate",
        "max_chars": 2000
      }
    }
  ],
  "task_paths": [
    "data/tasks/utility_core.json",
    "data/tasks/agentdojo_minimal.json",
    "data/tasks/custom_safety.json",
    "data/tasks/chat_safety_probes.json",
    "data/tasks/situational_awareness_probes.json",
    "data/tasks/agentharm_lite.json"
  ],
  "seeds": [0],
  "max_new_tokens": 256,
  "temperature": 0.0,
  "mitigation": {
    "triggered_escalation": {
      "enabled": true,
      "block_on_high_severity": true,
      "ask_confirmation_on_irreversible": true,
      "rerun_with_safer_profile": false
    }
  },
  "metadata": {
    "purpose": "No-GPU end-to-end collection rehearsal"
  }
}
