{
  "output_root": "runs/collection_rigorous_paper",
  "report_path": "reports/collection_rigorous_paper.md",
  "models": [
    {
      "provider": "hf",
      "model_id": "Qwen/Qwen2.5-7B-Instruct",
      "device_map": "auto",
      "torch_dtype": "float16",
      "metadata": {
        "label": "qwen25_7b",
        "role": "main_target",
        "rationale": "Primary model; strong open-weight instruction model with permissive license."
      }
    },
    {
      "provider": "hf",
      "model_id": "meta-llama/Llama-3.1-8B-Instruct",
      "device_map": "auto",
      "torch_dtype": "float16",
      "metadata": {
        "label": "llama31_8b",
        "role": "main_target",
        "rationale": "Reviewer-recognizable safety/alignment reference model.",
        "access_note": "Requires Hugging Face access approval and an authenticated token."
      }
    },
    {
      "provider": "hf",
      "model_id": "mistralai/Mistral-7B-Instruct-v0.3",
      "device_map": "auto",
      "torch_dtype": "float16",
      "metadata": {
        "label": "mistral_7b",
        "role": "main_target",
        "rationale": "Architecture and guardrail-diversity model with tool/function-calling support."
      }
    },
    {
      "provider": "hf",
      "model_id": "google/gemma-2-9b-it",
      "device_map": "auto",
      "torch_dtype": "float16",
      "metadata": {
        "label": "gemma2_9b",
        "role": "main_target",
        "rationale": "Google-family architecture diversity model.",
        "access_note": "May require accepting Google Gemma terms on Hugging Face."
      }
    },
    {
      "provider": "hf",
      "model_id": "Qwen/Qwen2.5-3B-Instruct",
      "device_map": "auto",
      "torch_dtype": "float16",
      "metadata": {
        "label": "qwen25_3b_control",
        "role": "size_control",
        "rationale": "Small-model control in the same family as the primary Qwen target."
      }
    },
    {
      "provider": "hf",
      "model_id": "Qwen/Qwen2.5-1.5B-Instruct",
      "device_map": "auto",
      "torch_dtype": "float16",
      "metadata": {
        "label": "qwen25_15b_fast_control",
        "role": "cheap_stress_control",
        "rationale": "Very cheap control for calibration, ablations, and early debugging."
      }
    }
  ],
  "transforms": [
    {
      "name": "fp16",
      "quantization": "none"
    },
    {
      "name": "int8",
      "quantization": "int8",
      "load_in_8bit": true
    },
    {
      "name": "nf4_4bit",
      "quantization": "nf4_4bit",
      "load_in_4bit": true,
      "bnb_4bit_quant_type": "nf4"
    },
    {
      "name": "pruned_magnitude_20",
      "quantization": "pruned",
      "metadata": {
        "pruning_amount": 0.2,
        "note": "Runnable pruning baseline. Replace with exported Wanda/SparseGPT checkpoints for the final pruning result if available."
      }
    },
    {
      "name": "context_truncate_2k",
      "quantization": "none",
      "context_compression": {
        "enabled": true,
        "mode": "truncate",
        "max_chars": 2000
      }
    }
  ],
  "task_paths": [
    "data/tasks/utility_core.json",
    "data/tasks/agentdojo_minimal.json",
    "data/tasks/custom_safety.json",
    "data/tasks/chat_safety_probes.json",
    "data/tasks/situational_awareness_probes.json",
    "data/tasks/agentharm_lite.json"
  ],
  "seeds": [0, 1, 2],
  "max_new_tokens": 256,
  "temperature": 0.0,
  "mitigation": {
    "triggered_escalation": {
      "enabled": true,
      "block_on_high_severity": true,
      "ask_confirmation_on_irreversible": true,
      "rerun_with_safer_profile": false
    }
  },
  "metadata": {
    "hardware_target": "single 24GB to 48GB GPU",
    "purpose": "Stronger main-conference model set with four main targets and two controls",
    "recommended_use": "Run after the smaller 24GB matrix is passing cleanly."
  }
}
